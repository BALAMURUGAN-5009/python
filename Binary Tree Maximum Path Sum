class Solution:
    def maxPathSum(self, root):
        self.max_sum = float('-inf')

        def get_contribution(node):
            if not node:
                return 0
            left = max(get_contribution(node.left), 0)
            right = max(get_contribution(node.right), 0)
            current_path_sum = node.val + left + right
            if current_path_sum > self.max_sum:
                self.max_sum = current_path_sum
            return node.val + max(left, right)

        get_contribution(root)
        return self.max_sum
